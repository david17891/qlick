{
  "name": "qlick-marketing-platform",
  "version": "0.9.9",
  "private": true,
  "description": "Plataforma LMS de cursos de marketing de Qlick Marketing Integral",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "node --experimental-test-module-mocks --import ./tests/loader-register.mjs --experimental-strip-types --test \"tests/*.test.mjs\"",
    "test:ci": "node tests/run-ci-tests.mjs",
    "test:e2e:funnel": "node --experimental-test-module-mocks --import ./tests/loader-register.mjs --experimental-strip-types --test tests/payments-events-funnel-e2e.test.mjs",
    "audit:links": "node scripts/audit-links.mjs",
    "audit:migrations": "node --env-file=.env.local scripts/audit-migrations-applied.mjs",
    "audit:voseo": "node scripts/audit-voseo.mjs",
    "check:supabase": "node scripts/check-supabase-env.mjs",
    "seed:courses": "node scripts/seed-courses.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "seed:demo:reset": "node scripts/seed-demo.mjs --reset",
    "seed:demo:cleanup": "node scripts/seed-demo.mjs --cleanup",
    "db:wipe": "node scripts/db-wipe.mjs",
    "smoke:audit": "node --import ./tests/loader-register.mjs --experimental-strip-types scratch/audit-edge-cases.mjs",
    "smoke:scenarios": "node --import ./tests/loader-register.mjs --experimental-strip-types scratch/simulate-scenarios.mjs",
    "smoke": "npm run test && npm run type-check && npm run lint && npm run smoke:scenarios && npm run smoke:audit"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "@react-pdf/renderer": "^4.5.1",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.25.0",
    "next": "14.2.35",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^22.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "pg": "^8.22.0",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3"
  }
}
