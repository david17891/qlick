# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env
.env*.local
.env.development
.env.production

# vercel
.vercel

# supabase
# config.toml puede contener el project ref real del proyecto local;
# se versiona solo la plantilla config.example.toml.
/supabase/config.toml
/supabase/.branches
/supabase/.temp

# typescript
*.tsbuildinfo
next-env.d.ts

# editor
.vscode/*
!.vscode/extensions.json
.idea

# extractores temporales
/_brand_extract

# artefacto de MSYS/Git-Bash en Windows: `nul` es dispositivo reservado,
# pero a veces se materializa como archivo suelto por redirecciones mal
# interpretadas (ej. `2>nul`). Lo ignoramos para que nunca entre al repo.
/nul
