.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env
.env*.local
.env.development
.env.production

# vercel
.vercel

# supabase
# config.toml puede contener el project ref real del proyecto local;
# se versiona solo la plantilla config.example.toml.
/supabase/config.toml
/supabase/.branches
/supabase/.temp

# typescript
*.tsbuildinfo
next-env.d.ts

# editor
.vscode/*
!.vscode/extensions.json
.idea

# extractores temporales
/_brand_extract

# artefacto de MSYS/Git-Bash en Windows: `nul` es dispositivo reservado,
# pero a veces se materializa como archivo suelto por redirecciones mal
# interpretadas (ej. `2>nul`). Lo ignoramos para que nunca entre al repo.
/nul

# scripts de debug/auth de admin (no son parte del producto, son herramientas
# locales de desarrollo: kill-dev.ps1 mata listeners 3000/3001;
# generate-magic-link.mjs genera magic links via Admin API para debug PKCE).
# Si los necesitas en otro equipo, regenera desde el handoff histórico:
# docs/HANDOFF_v0.5.0_ADMIN_AUTH_LEADS.md
/scripts/generate-magic-link.mjs
/scripts/kill-dev.ps1

# body temporal de PR (se borra después de crear el PR con `gh pr create`)
/PR_BODY.md

dev-server.log
