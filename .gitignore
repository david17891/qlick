# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# Mavis (mavis) runtime state — planes, scratchpads, hooks. Local al agente,
# nunca debe entrar al repo.
.mavis/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env
.env*.local
.env.development
.env.production

# vercel
.vercel

# supabase
# config.toml puede contener el project ref real del proyecto local;
# se versiona solo la plantilla config.example.toml.
/supabase/config.toml
/supabase/.branches
/supabase/.temp

# typescript
*.tsbuildinfo
next-env.d.ts

# editor
.vscode/*
!.vscode/extensions.json
.idea

# extractores temporales
/_brand_extract

# artefacto de MSYS/Git-Bash en Windows: `nul` es dispositivo reservado,
# pero a veces se materializa como archivo suelto por redirecciones mal
# interpretadas (ej. `2>nul`). Lo ignoramos para que nunca entre al repo.
/nul

# artefactos efímeros del MCP de Playwright (`mavis mcp call playwright ...`).
# Cada sesión del MCP regenera configs y screenshots intermedios aquí. No son
# parte del producto — son ruido local del agente.
.playwright-mcp/

# scripts de debug/auth de admin (no son parte del producto, son herramientas
# locales de desarrollo: kill-dev.ps1 mata listeners 3000/3001;
# generate-magic-link.mjs genera magic links via Admin API para debug PKCE).
# Si los necesitas en otro equipo, regenera desde el handoff histórico:
# docs/HANDOFF_v0.5.0_ADMIN_AUTH_LEADS.md
/scripts/generate-magic-link.mjs
/scripts/kill-dev.ps1

# body temporal de PR (se borra después de crear el PR con `gh pr create`)
/PR_BODY.md

# Logs efímeros del dev server local (rotan entre sesiones del agente).
# Patrón cubre tanto los nombres viejos (`dev-server.log`,
# `dev-server.err.log`) como los nuevos (`dev-out.log`, `dev-err.log`).
dev-*.log

# ============================================================================
# Política de datos — NUNCA commitear datos personales / PII
# ============================================================================
# Los Excels de eventos/conferencias/clientes y cualquier archivo con datos
# personales (nombres, teléfonos, emails reales) NUNCA deben entrar al repo.
#
# Patrones cubiertos:
#  - /private-data/  → carpeta de uso local del socio/equipo, fuera del repo
#  - /datos-privados/ → equivalente en español
#  - lista_*.xlsx, asistencia_*.xlsx, clientes_*.xlsx, encuesta_*.xlsx → Excels típicos
#  - *.csv con datos de leads/eventos → si los hay, deben ir a private-data/
#
# Los datos reales SÍ se usan para operación local (Supabase, admin privado,
# demo privada del socio). NO se usan en: tests, fixtures, screenshots
# públicas, logs, ni commits. Para tests usar siempre datos sintéticos
# (nombres falsos, teléfonos +52XXXXXXXXXX, emails @example.com).
#
# Ver docs/ROADMAP.md → "Política de datos" para el detalle completo.
/private-data/
/datos-privados/
/lista_*.xlsx
/asistencia_*.xlsx
/clientes_*.xlsx
/encuesta_*.xlsx
/leads_*.xlsx
/evento_*.xlsx

# --- Artefactos de presentaciones a socios (no van al repo) ---
/junta-socios-*
# --- Scripts temporales generados por sesiones Mavis (cookies, evals, etc.) ---
# Patrón: archivos en scripts/ que arrancan con tmp- (cookies, login JSON, etc.).
/scripts/tmp-*.json

# --- Backups de .env.local creados durante cleanup de encoding (Mojibake fix) ---
# Patron: cuando un script regenera .env.local, deja un `.bak-<timestamp>` junto.
# Contiene secretos -> NUNCA debe commitear.
/.env.local.bak-*
