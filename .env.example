# =============================================================
# Qlick Marketing Digital — Variables de entorno (ejemplo)
# Copia este archivo como .env.local y completa lo que uses.
# El MVP funciona sin ninguna de estas variables (modo mock).
# =============================================================

# --- App general ---
NEXT_PUBLIC_APP_NAME="Qlick Marketing Digital"
# URL canónica de la app. En local: http://localhost:3000. En prod: la de Vercel.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BRAND_PRIMARY="#AB3FEA"
NEXT_PUBLIC_BRAND_ACCENT="#EF9F08"

# --- Modo del MVP ---
# "mock" usa datos en memoria. "supabase" activa auth/DB real (fase 1).
NEXT_PUBLIC_AUTH_MODE="mock"
NEXT_PUBLIC_PAYMENT_PROVIDER="mock"

# --- Supabase (bootstrap de conexión — fase 1) ---
# La app compila y corre en modo demo aunque estas variables estén vacías.
# Documentación: docs/SUPABASE_CONNECTION_BOOTSTRAP.md
#
# URL del proyecto (pública). Ej: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=""
# Publishable key (antes "anon key"). Pública, respeta RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Secret key (≈ service role). BYPASSA RLS. SOLO server-side. Nunca NEXT_PUBLIC_*.
# NUNCA importar src/lib/supabase/admin.ts desde un Client Component.
SUPABASE_SECRET_KEY=""
# Project ref (para CLI/MCP). Ej: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SUPABASE_PROJECT_REF=""
#
# --- Alias legacy (compatibilidad con setups previos) ---
# Si tu .env.local ya usa estos nombres, los clientes los aceptan como fallback.
# Para nuevos setups, prefiere los nombres estandarizados de arriba.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
#
# --- Auth admin (v0.5.0) ---
# Lista de emails autorizados para acceder a /admin/* y /api/admin/*.
# Server-only. Coma-separada, sin espacios. Ejemplo:
# ADMIN_EMAIL_ALLOWLIST="david17891@gmail.com,layerzero3dprint@gmail.com"
ADMIN_EMAIL_ALLOWLIST=""

# --- Dev login bypass (v0.6.0) ---
# Secret compartido para usar /dev/login (bypass de magic link en dev).
# Este endpoint devuelve 404 en NODE_ENV=production, así que es seguro
# aunque quede configurado en el server de producción.
# Genera uno con: openssl rand -hex 32
# En .env.local (NUNCA comitear el valor real):
# DEV_ADMIN_SECRET=""

# --- Pagos (Stripe activo en Fase 1; MercadoPago/Conekta siguen como stubs) ---
# Proveedor activo se elige con NEXT_PUBLIC_PAYMENT_PROVIDER (mock | stripe | mercadopago | conekta).
# Por defecto: mock (sigue funcionando con SimulatorForm mientras se migra a Stripe real).
# Si usas Stripe:
#   - STRIPE_SECRET_KEY: sk_test_... en test mode, sk_live_... en prod.
#   - STRIPE_WEBHOOK_SECRET: whsec_... se obtiene al registrar el endpoint en
#     Stripe Dashboard (o via `stripe listen` en dev).
#   - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: pk_test_... / pk_live_... (frontend).
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
CONEKTA_API_KEY=""
CONEKTA_PRIVATE_KEY=""

# --- Video (fase 3, opcional en MVP) ---
# Por defecto se usa YouTube no listado. Ver docs/VIDEO_STRATEGY.md.
CLOUDFLARE_STREAM_CUSTOMER_CODE=""
MUX_ACCESS_TOKEN=""
MUX_SECRET_ID=""

# --- Webhooks (fase 2) ---
PAYMENT_WEBHOOK_SECRET=""

# --- Contacto y WhatsApp ---
# El proveedor activo de contacto. "mock" (demo) por defecto.
NEXT_PUBLIC_CONTACT_PROVIDER="mock"
# Destino real de los mensajes cuando se active resend/crm.
NEXT_PUBLIC_CONTACT_TO_EMAIL="hola@qlick.mx"
# Números de WhatsApp en formato internacional (ej. 5212222222222).
# Si se omiten, los botones de WhatsApp se muestran como "próximamente".
NEXT_PUBLIC_WHATSAPP_SALES_NUMBER=""
NEXT_PUBLIC_WHATSAPP_SUPPORT_NUMBER=""
# URL completa del grupo de alumnos (chat.whatsapp.com/...).
# NO inventar: debe ser proporcionada manualmente por Qlick.
NEXT_PUBLIC_WHATSAPP_GROUP_URL=""
# --- Email transaccional (Brevo, Fase 7b — migración 2026-07-02) ---
# Setup: https://app.brevo.com → signup → Settings → Senders & Domains
# → Add domain qlick.digital → Brevo te da 3 records DNS (Brevo code CNAME,
# DKIM TXT, DMARC TXT) → pegarlos en Cloudflare DNS.
# → API key: Settings → SMTP & API → API keys → crear (scope: send emails).
# Free tier: 300 emails/día, sin cap mensual. Suficiente para Qlick MVP.
# SDK Node oficial (`@getbrevo/brevo` en package.json).
# Docs paso a paso: docs/SMTP_SETUP.md
#
# En NODE_ENV=development, si BREVO_API_KEY está vacía, los emails se
# loggean en consola en lugar de enviarse. Nunca crashea el flow principal.
BREVO_API_KEY=""
# From address. Debe estar validado en Brevo (registros SPF/DKIM/DMARC).
# Formato: "Nombre <email@dominio>" o "email@dominio".
BREVO_FROM_ADDRESS="Qlick <noreply@qlick.digital>"
# Reply-to: cuando David hace "Responder" en Gmail, llega a este email.
BREVO_REPLY_TO="david17891@gmail.com"
# --- Lista de admins que reciben notificaciones de leads nuevos ---
# CSV sin espacios. Si se omite, no se mandan emails (la app loggea warning
# y sigue funcionando — la notification es best-effort, no bloqueante).
# Reusar ADMIN_EMAIL_ALLOWLIST es tentador pero ese es para auth; las
# notificaciones son orthogonales (puedes notificar a gente que NO es admin).
ADMIN_NOTIFICATION_EMAILS="david17891@gmail.com"

# --- Bot WhatsApp + Meta Marketing API (Fase 6 Hito C) ---
# Server-only, NUNCA NEXT_PUBLIC_*.
#
# Proveedor activo de WhatsApp. "manual_wa" (default, click-to-chat wa.me),
# "meta_cloud_api" (bot conversacional real con webhook), "bsp" (stub).
# Docs: docs/WHATSAPP_OFFICIAL_INTEGRATION_PLAN.md, docs/PARTNER_META_SETUP.md
#
# El WABA + App + Phone Number son de un cliente UNICO (Qlick Marketing Digital).
# Patrón multi-cliente: CADA cliente del portafolio tiene su propio WABA dedicado.
# Ver docs/PARTNER_META_SETUP.md seccion "Patron multi-cliente".
NEXT_PUBLIC_WHATSAPP_PROVIDER="manual_wa"
# App ID de Meta for Developers. Lo encontras arriba a la izquierda en
# https://developers.facebook.com/apps/ despues de crear la App tipo "Negocios".
# Necesario para el handshake del webhook y para el System User token.
WHATSAPP_CLOUD_APP_ID=""
# ID del WhatsApp Business Account (WABA). Lo da Meta al crear el WABA.
# Difiere del Phone Number ID: WABA = la cuenta, Phone Number ID = el numero dentro.
WHATSAPP_CLOUD_WABA_ID=""
# ID del numero de WhatsApp dentro de la WABA. Lo da Meta for Developers → WhatsApp → API Setup.
WHATSAPP_CLOUD_PHONE_NUMBER_ID=""
# Token permanente (System User). Cuidalo como contrasena: si se filtra,
# cualquiera puede mandar mensajes desde tu WhatsApp.
# Permisos requeridos: whatsapp_business_management, whatsapp_business_messaging.
WHATSAPP_CLOUD_ACCESS_TOKEN=""
WHATSAPP_CLOUD_API_VERSION="v20.0"
# Token de verificacion del webhook (el que se le pasa a Meta en el GET handshake).
# Generar con: openssl rand -hex 32
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
# Secret para validar X-Hub-Signature-256 (HMAC SHA256). Si esta vacio, el
# webhook NO valida firma (dev friendly, NO recomendado en prod).
WHATSAPP_WEBHOOK_SECRET=""

# --- Meta Marketing API (lectura de campañas + atribución) ---
# Mismo Access Token del WABA o un System User dedicado a Insights.
# Permisos mínimos: ads_read, business_management, read_insights.
META_ACCESS_TOKEN=""
# Formato `act_1234567890`. Lo encontrás en Meta Ads Manager → Configuración.
META_AD_ACCOUNT_ID=""
# Opcional, para Conversions API (futuro).
META_PIXEL_ID=""

# --- Agente IA (bot conversacional) ---
# Proveedor: "mock" (heurística), "openrouter" (stub), "deepseek" (V4-Flash, real).
# Si DEEPSEEK_API_KEY está seteada y AI_AGENT_PROVIDER NO está seteado, usa deepseek.
AI_AGENT_PROVIDER=""
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"

# --- Evento activo para el bot (Fase 6 piloto) ---
# Configurables runtime (sin redeploy). Si están vacíos, el bot usa
# placeholders genéricos.
EVENT_NAME="Conferencia IA y Marketing Básico"
EVENT_DATE="6 de julio"
EVENT_LOCATION="Ciudad de México"
EVENT_DURATION="2 horas"

# --- CRM (futura fase, opcional) ---
CRM_API_KEY=""
