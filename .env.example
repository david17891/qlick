# =============================================================
# Qlick Marketing Integral — Variables de entorno (ejemplo)
# Copia este archivo como .env.local y completa lo que uses.
# El MVP funciona sin ninguna de estas variables (modo mock).
# =============================================================

# --- App general ---
NEXT_PUBLIC_APP_NAME="Qlick Marketing Integral"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BRAND_PRIMARY="#AB3FEA"
NEXT_PUBLIC_BRAND_ACCENT="#EF9F08"

# --- Modo del MVP ---
# "mock" usa datos en memoria. "supabase" activa auth/DB real (fase 1).
NEXT_PUBLIC_AUTH_MODE="mock"
NEXT_PUBLIC_PAYMENT_PROVIDER="mock"

# --- Supabase (fase 1, opcional en MVP) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Pagos (fase 2, opcional en MVP) ---
# El proveedor activo se elige con NEXT_PUBLIC_PAYMENT_PROVIDER.
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
CONEKTA_API_KEY=""
CONEKTA_PRIVATE_KEY=""

# --- Video (fase 3, opcional en MVP) ---
# Por defecto se usa YouTube no listado. Ver docs/VIDEO_STRATEGY.md.
CLOUDFLARE_STREAM_CUSTOMER_CODE=""
MUX_ACCESS_TOKEN=""
MUX_SECRET_ID=""

# --- Webhooks (fase 2) ---
PAYMENT_WEBHOOK_SECRET=""
