# =============================================================
# Qlick Marketing Integral — Variables de entorno (ejemplo)
# Copia este archivo como .env.local y completa lo que uses.
# El MVP funciona sin ninguna de estas variables (modo mock).
# =============================================================

# --- App general ---
NEXT_PUBLIC_APP_NAME="Qlick Marketing Integral"
# URL canónica de la app. En local: http://localhost:3000. En prod: la de Vercel.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BRAND_PRIMARY="#AB3FEA"
NEXT_PUBLIC_BRAND_ACCENT="#EF9F08"

# --- Modo del MVP ---
# "mock" usa datos en memoria. "supabase" activa auth/DB real (fase 1).
NEXT_PUBLIC_AUTH_MODE="mock"
NEXT_PUBLIC_PAYMENT_PROVIDER="mock"

# --- Supabase (bootstrap de conexión — fase 1) ---
# La app compila y corre en modo demo aunque estas variables estén vacías.
# Documentación: docs/SUPABASE_CONNECTION_BOOTSTRAP.md
#
# URL del proyecto (pública). Ej: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=""
# Publishable key (antes "anon key"). Pública, respeta RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Secret key (≈ service role). BYPASSA RLS. SOLO server-side. Nunca NEXT_PUBLIC_*.
# NUNCA importar src/lib/supabase/admin.ts desde un Client Component.
SUPABASE_SECRET_KEY=""
# Project ref (para CLI/MCP). Ej: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SUPABASE_PROJECT_REF=""
#
# --- Alias legacy (compatibilidad con setups previos) ---
# Si tu .env.local ya usa estos nombres, los clientes los aceptan como fallback.
# Para nuevos setups, prefiere los nombres estandarizados de arriba.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
#
# --- Auth admin (v0.5.0) ---
# Lista de emails autorizados para acceder a /admin/* y /api/admin/*.
# Server-only. Coma-separada, sin espacios. Ejemplo:
# ADMIN_EMAIL_ALLOWLIST="david17891@gmail.com,layerzero3dprint@gmail.com"
ADMIN_EMAIL_ALLOWLIST=""

# --- Dev login bypass (v0.6.0) ---
# Secret compartido para usar /dev/login (bypass de magic link en dev).
# Este endpoint devuelve 404 en NODE_ENV=production, así que es seguro
# aunque quede configurado en el server de producción.
# Genera uno con: openssl rand -hex 32
# En .env.local (NUNCA comitear el valor real):
# DEV_ADMIN_SECRET=""

# --- Pagos (fase 2, opcional en MVP) ---
# El proveedor activo se elige con NEXT_PUBLIC_PAYMENT_PROVIDER.
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
CONEKTA_API_KEY=""
CONEKTA_PRIVATE_KEY=""

# --- Video (fase 3, opcional en MVP) ---
# Por defecto se usa YouTube no listado. Ver docs/VIDEO_STRATEGY.md.
CLOUDFLARE_STREAM_CUSTOMER_CODE=""
MUX_ACCESS_TOKEN=""
MUX_SECRET_ID=""

# --- Webhooks (fase 2) ---
PAYMENT_WEBHOOK_SECRET=""

# --- Contacto y WhatsApp ---
# El proveedor activo de contacto. "mock" (demo) por defecto.
NEXT_PUBLIC_CONTACT_PROVIDER="mock"
# Destino real de los mensajes cuando se active resend/crm.
NEXT_PUBLIC_CONTACT_TO_EMAIL="hola@qlick.mx"
# Números de WhatsApp en formato internacional (ej. 5212222222222).
# Si se omiten, los botones de WhatsApp se muestran como "próximamente".
NEXT_PUBLIC_WHATSAPP_SALES_NUMBER=""
NEXT_PUBLIC_WHATSAPP_SUPPORT_NUMBER=""
# URL completa del grupo de alumnos (chat.whatsapp.com/...).
# NO inventar: debe ser proporcionada manualmente por Qlick.
NEXT_PUBLIC_WHATSAPP_GROUP_URL=""
# --- Email transaccional (Resend, Fase 5) ---
# Setup: https://resend.com → signup con GitHub → verify domain qlick.marketing
# → API key (scope: "send transactional emails").
# Free tier: 100 emails/día, 3,000/mes. SDK Node oficial (`resend` en package.json).
# Docs paso a paso: docs/SMTP_SETUP.md
#
# En NODE_ENV=development, si RESEND_API_KEY está vacía, los emails se
# loggean en consola en lugar de enviarse. Nunca crashea el flow principal.
RESEND_API_KEY=""
# From address. Debe estar validado en Resend (registros SPF/DKIM/DMARC).
RESEND_FROM_ADDRESS="notificaciones@qlick.marketing"
# Reply-to: cuando David hace "Responder" en Gmail, llega a este email.
RESEND_REPLY_TO="david17891@gmail.com"
# --- Lista de admins que reciben notificaciones de leads nuevos ---
# CSV sin espacios. Si se omite, no se mandan emails (la app loggea warning
# y sigue funcionando — la notification es best-effort, no bloqueante).
# Reusar ADMIN_EMAIL_ALLOWLIST es tentador pero ese es para auth; las
# notificaciones son orthogonales (puedes notificar a gente que NO es admin).
ADMIN_NOTIFICATION_EMAILS="david17891@gmail.com"

# --- CRM (futura fase, opcional) ---
CRM_API_KEY=""
